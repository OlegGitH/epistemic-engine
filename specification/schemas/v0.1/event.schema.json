{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epistemic.dev/schemas/v0.1/event.schema.json",
  "title": "Epistemic Protocol Event",
  "type": "object",
  "required": ["spec_version", "id", "type", "source", "subject", "time", "data"],
  "properties": {
    "spec_version": { "const": "0.1" },
    "id": { "type": "string", "minLength": 1 },
    "type": { "enum": ["decision.started", "decision.requested", "decision.evaluated", "decision.blocked", "decision.approved", "decision.completed", "claim.declared", "claim.updated", "claim.supported", "claim.contradicted", "claim.superseded", "claim.rejected", "evidence.discovered", "evidence.attached", "evidence.expired", "evidence.invalidated", "assumption.declared", "assumption.resolved", "unknown.declared", "unknown.resolved", "contradiction.detected", "contradiction.resolved", "verification.requested", "verification.approved", "verification.started", "verification.completed", "verification.failed", "proof.issued", "proof.revoked", "proof.superseded"] },
    "source": { "$ref": "#/$defs/source" },
    "subject": { "$ref": "#/$defs/subject" },
    "time": { "type": "string", "format": "date-time" },
    "context": { "$ref": "#/$defs/context" },
    "ordering": { "$ref": "#/$defs/ordering" },
    "idempotency_key": { "type": "string" },
    "data": true,
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true,
  "$defs": {
    "source": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string", "minLength": 1 }, "version": { "type": "string" }, "instance": { "type": "string" } }, "additionalProperties": false },
    "subject": { "type": "object", "required": ["type", "id"], "properties": { "type": { "type": "string", "minLength": 1 }, "id": { "type": "string", "minLength": 1 } }, "additionalProperties": false },
    "context": { "type": "object", "properties": { "decision_id": { "type": "string" }, "run_id": { "type": "string" }, "correlation_id": { "type": "string" }, "parent_id": { "type": "string" } }, "additionalProperties": false },
    "ordering": { "type": "object", "properties": { "sequence": { "type": "integer", "minimum": 0 }, "partition": { "type": "string" } }, "additionalProperties": false }
  }
}
