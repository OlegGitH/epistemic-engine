@@ -0,0 +1,14 @@
+import unittest
+
+from orders.migration import migrate_status
+
+
+class CurrentStatusCompatibilityTest(unittest.TestCase):
+    def test_supported_statuses_round_trip_unchanged(self) -> None:
+        for stored_status in ("pending", "in_progress", "completed"):
+            with self.subTest(stored_status=stored_status):
+                self.assertEqual(migrate_status(stored_status).value, stored_status)
+
+
+if __name__ == "__main__":
+    unittest.main()
